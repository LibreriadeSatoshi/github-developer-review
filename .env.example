# =====================================================
# Authentication (required)
# =====================================================

# Session encryption secret.
# Generate: openssl rand -base64 32
AUTH_SECRET=

# GitHub OAuth App — https://github.com/settings/developers
# Callback URL: http://localhost:3000/api/auth/callback/github (dev)
#               https://\<your-domain\>/api/auth/callback/github (prod)
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# =====================================================
# Cache (optional — app runs uncached if absent)
# =====================================================

# Upstash Redis REST — https://console.upstash.com/
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# =====================================================
# Observability (optional)
# =====================================================

# Set to "TRUE" to enable verbose console.error output.
# Default: disabled (no output).
DEBUG_CONSOLE=

# =====================================================
# Persistence (Supabase — required for save/export)
# =====================================================

# Supabase project URL and service role key — https://supabase.com/dashboard
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# =====================================================
# Build metadata (auto-injected by Netlify — do not set locally)
# =====================================================
# COMMIT_REF=
